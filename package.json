{
  "name": "civilization-spark",
  "description": "SLG策略游戏 - 末日生存与领地建设",
  "version": "1.1.0",
  "license": "MIT",
  "keywords": [
    "phaser",
    "phaser3",
    "react",
    "vite",
    "typescript"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "assets:check": "node ./scripts/assets/check-assets.mjs",
    "assets:check:strict": "node ./scripts/assets/check-assets.mjs --strict",
    "test": "vitest",
    "test:e2e": "node ./scripts/e2e/run-e2e.mjs",
    "cy:run": "cypress run",
    "lint": "eslint .",
    "lint:style": "stylelint \"**/*.css\"",
    "hooks:install": "node ./scripts/git-hooks/install.mjs",
    "commit:template": "node ./scripts/git/commit-template.mjs"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.5",
    "bitcoinjs-lib": "^7.0.1",
    "phaser": "^3.90.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "cypress": "^15.11.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.1.5",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.28.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1",
    "vitest": "^4.0.18"
